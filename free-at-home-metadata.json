{
  "name": "Nuki Smart Lock (local API) Integration",
  "version": "1.2.3",
  "id": "tech.michalk.freeathome.nuki",
  "license": "MIT",
  "description": "Integration von Nuki Smart Locks in das Busch-Jäger free@home System. Unterstützt mehrere Bridges und Schlösser mit automatischer Status-Synchronisation.",
  "url": "https://www.michalk.tech",
  "author": "Peter Michalk",
  "type": "app",
  "entryPoint": "build/main.js",
  "parameters": {
    "bridge": {
      "name": "Nuki Bridge",
      "multiple": true,
      "items": {
        "ip": {
          "name": "IP-Adresse",
          "type": "ipv4",
          "required": true
        },
        "token": {
          "name": "API Token",
          "type": "password",
          "required": true
        },
        "port": {
          "name": "Port",
          "type": "number",
          "default": 8080,
          "min": 1,
          "max": 65535
        },
        "pollInterval": {
          "name": "Poll-Intervall (ms)",
          "type": "number",
          "default": 30000,
          "min": 1000,
          "max": 60000
        }
      }
    },
    "lock": {
      "name": "Nuki Schloss",
      "multiple": true,
      "items": {
        "id": {
          "name": "Lock ID",
          "type": "string",
          "required": true
        },
        "name": {
          "name": "Name",
          "type": "string",
          "required": true
        },
        "bridgeIp": {
          "name": "Bridge IP",
          "type": "ipv4",
          "required": true
        }
      }
    }
  }
}
